# Ignore extensionless files (typically binary build outputs).
# Common text files without extension are explicitly allowed.
*
!*.*
!*/
!Makefile
!Dockerfile
!LICENSE
!README

# Binary file extensions (re-ignore after !*.* above)
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go
*.test
*.out
coverage.out
coverage.html
vendor/

# Go workspace file (optional local override)
# go.work

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/

# Environment
.env
.env.local
*.pem

# BuildX runtime data
buildx-server/data/
*.db
*.sqlite

# Maven
target/

# buildx-server
buildx-server/dist/
buildx-server/internal/server/webdist/

# buildx-web
buildx-web/node_modules/
buildx-web/dist/
# synced from references/onedev — regenerate via make sync-onedev-assets
buildx-web/public/onedev/
buildx-web/public/~icon/
buildx-web/public/~img/
